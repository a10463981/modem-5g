#!/bin/sh /etc/rc.common
# Fixed for iStoreOS / ImmortalWrt (Ash shell compatible)
# 关键修复：
#   1. 用反引号替代 $() — Ash shell 不支持 $()
#   2. 不再 unbind/rebind qmi_wwan — kernel boot 时已正确创建 wwan0

START=20
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command "/bin/sh" "-c" "
        for i in \`seq 1 30\`; do
            [ -d /sys/bus/usb/devices/2-1 ] && break
            sleep 1
        done
        
        vid=\`cat /sys/bus/usb/devices/2-1/idVendor 2>/dev/null\`
        pid=\`cat /sys/bus/usb/devices/2-1/idProduct 2>/dev/null\`
        if [ \"\$vid:\$pid\" = \"2c7c:0801\" ]; then
            for i in \`seq 1 20\`; do
                [ -e /dev/wwan0 ] && break
                sleep 1
            done
            [ -e /dev/wwan0 ] && ip link set wwan0 up 2>/dev/null
            [ -e /dev/wwan0 ] && echo 'usbmode: wwan0 ready'
        fi
    "
    procd_close_instance
}

stop_service() {
    :
}
